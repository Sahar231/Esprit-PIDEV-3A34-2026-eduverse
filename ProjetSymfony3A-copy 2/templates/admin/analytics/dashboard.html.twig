{% extends 'base.html.twig' %}

{% block title %}Analytics Dashboard - Admin{% endblock %}

{% block body %}
<main>
    <!-- Page Banner START -->
    <section class="pt-0">
        <div class="container-fluid px-0">
            <div class="card bg-blue h-100px h-md-200px rounded-0" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);"></div>
        </div>
        <div class="container mt-n4 mb-4">
            <div class="row">
                <div class="col-12">
                    <div class="card bg-transparent card-body pb-0 px-0">
                        <div class="d-flex align-items-center justify-content-between flex-wrap">
                            <div>
                                <h1 class="fs-2 mb-1">
                                    <i class="fas fa-chart-line me-2"></i>Analytics Dashboard
                                </h1>
                                <p class="text-body mb-0">Real-time insights about your platform • Last updated: <strong>{{ metrics.lastUpdated|date('H:i') }}</strong></p>
                            </div>
                            <div class="mt-3 mt-md-0 d-flex gap-2">
                                <a href="{{ path('admin_dashboard') }}" class="btn btn-sm btn-outline-secondary" title="Return to admin dashboard">
                                    <i class="fas fa-arrow-left me-1"></i>Back to Dashboard
                                </a>
                                <button class="btn btn-sm btn-white" onclick="location.reload()" title="Refresh data">
                                    <i class="fas fa-sync-alt me-1"></i>Refresh
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- Page Banner END -->

    <!-- Analytics Content START -->
    <section class="py-5">
        <div class="container">
            <!-- KEY METRICS SECTION -->
            <div class="row g-4 mb-5">
                <!-- Total Revenue Card -->
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm h-100 position-relative overflow-hidden">
                        <div class="position-absolute top-0 end-0 w-25 h-25 bg-success bg-opacity-5 rounded-3"></div>
                        <div class="card-body p-4 position-relative">
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <h6 class="card-title mb-0 fw-bold">Total Revenue</h6>
                                <div class="bg-success bg-opacity-10 p-3 rounded-2" style="width: 50px; height: 50px; display: flex; align-items: center; justify-content: center;">
                                    <i class="fas fa-euro-sign text-success fs-5"></i>
                                </div>
                            </div>
                            <h2 class="text-success mb-3 fw-bold">€{{ "%.2f"|format(metrics.totalRevenue) }}</h2>
                            <div class="d-flex align-items-center gap-2">
                                <small class="badge bg-success bg-opacity-10 text-success px-3 py-2">
                                    <i class="fas fa-arrow-up me-1"></i>Last 30 days
                                </small>
                            </div>
                            <div class="mt-4 pt-3 border-top">
                                <small class="text-success fw-5">
                                    <i class="fas fa-check-circle me-1"></i>From wallet purchases & course sales
                                </small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Average Dropout Rate Card -->
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm h-100 position-relative overflow-hidden">
                        <div class="position-absolute top-0 end-0 w-25 h-25 bg-{% if metrics.avgDropoutRate > 40 %}danger{% else %}warning{% endif %} bg-opacity-5 rounded-3"></div>
                        <div class="card-body p-4 position-relative">
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <h6 class="card-title mb-0 fw-bold">Student Retention</h6>
                                <div class="bg-{% if metrics.avgDropoutRate > 40 %}danger{% else %}warning{% endif %} bg-opacity-10 p-3 rounded-2" style="width: 50px; height: 50px; display: flex; align-items: center; justify-content: center;">
                                    <i class="fas fa-chart-pie text-{% if metrics.avgDropoutRate > 40 %}danger{% else %}warning{% endif %} fs-5"></i>
                                </div>
                            </div>
                            <h2 class="text-{% if metrics.avgDropoutRate > 40 %}danger{% else %}success{% endif %} mb-3 fw-bold">
                                {{ 100 - metrics.avgDropoutRate|round(1) }}%
                            </h2>
                            <div class="progress mb-3" style="height: 8px;">
                                <div class="progress-bar bg-{% if metrics.avgDropoutRate > 40 %}danger{% else %}success{% endif %}" role="progressbar" style="width: {{ 100 - metrics.avgDropoutRate }}%" aria-valuenow="{{ 100 - metrics.avgDropoutRate }}" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                            <div class="mt-3 pt-3 border-top">
                                <small class="text-{% if metrics.avgDropoutRate > 40 %}danger{% else %}success{% endif %} fw-5">
                                    {% if metrics.avgDropoutRate > 40 %}
                                        <i class="fas fa-exclamation-triangle me-1"></i>Action needed
                                    {% else %}
                                        <i class="fas fa-check-circle me-1"></i>Good performance
                                    {% endif %}
                                </small>
                                <br>
                                <small class="text-muted mt-2 d-block">Dropout: {{ metrics.avgDropoutRate }}%</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Credits Sold Card -->
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm h-100 position-relative overflow-hidden">
                        <div class="position-absolute top-0 end-0 w-25 h-25 bg-info bg-opacity-5 rounded-3"></div>
                        <div class="card-body p-4 position-relative">
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <h6 class="card-title mb-0 fw-bold">Credits Sold</h6>
                                <div class="bg-info bg-opacity-10 p-3 rounded-2" style="width: 50px; height: 50px; display: flex; align-items: center; justify-content: center;">
                                    <i class="fas fa-coins text-info fs-5"></i>
                                </div>
                            </div>
                            <h2 class="text-info mb-3 fw-bold">{{ metrics.totalCreditsSold.credits|number_format }}</h2>
                            <div class="bg-info bg-opacity-10 rounded p-2 mb-3">
                                <strong class="text-info">€{{ "%.2f"|format(metrics.totalCreditsSold.revenue) }}</strong>
                                <small class="text-muted d-block">Revenue generated</small>
                            </div>
                            <small class="text-info fw-5">
                                <i class="fas fa-certificate me-1"></i>Units sold
                            </small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ADDITIONAL METRICS ROW -->
            <div class="row g-4 mb-5">
                <div class="col-lg-3 col-md-6">
                    <div class="card border-0 shadow-sm text-center">
                        <div class="card-body p-3">
                            <h6 class="text-muted small mb-2">AVG REVENUE/FORMATION</h6>
                            <h3 class="text-primary fw-bold">€{{ "%.2f"|format(metrics.topFormations|reduce((sum, f) => sum + f.revenue, 0) / (metrics.topFormations|length ?: 1)) }}</h3>
                            <small class="text-muted"><i class="fas fa-chart-bar me-1"></i>{{ metrics.topFormations|length }} formations</small>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="card border-0 shadow-sm text-center">
                        <div class="card-body p-3">
                            <h6 class="text-muted small mb-2">TOTAL ENROLLMENTS</h6>
                            <h3 class="text-success fw-bold">{{ metrics.topFormations|reduce((sum, f) => sum + f.enrollments, 0) }}</h3>
                            <small class="text-muted"><i class="fas fa-users me-1"></i>Active students</small>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="card border-0 shadow-sm text-center">
                        <div class="card-body p-3">
                            <h6 class="text-muted small mb-2">TOP FORMATION</h6>
                            <h3 class="text-warning fw-bold" style="font-size: 1.1rem; word-break: break-word;">{{ metrics.topFormations[0].name ?? 'N/A' }}</h3>
                            <small class="text-muted"><i class="fas fa-star me-1"></i>€{{ metrics.topFormations[0].revenue ?? 0|number_format('2', '.', ',') }}</small>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="card border-0 shadow-sm text-center">
                        <div class="card-body p-3">
                            <h6 class="text-muted small mb-2">PLATFORM HEALTH</h6>
                            <h3 class="fw-bold {% if metrics.avgDropoutRate <= 30 %}text-success{% elseif metrics.avgDropoutRate <= 45 %}text-warning{% else %}text-danger{% endif %}">
                                {% if metrics.avgDropoutRate <= 30 %}Excellent{% elseif metrics.avgDropoutRate <= 45 %}Good{% else %}At Risk{% endif %}
                            </h3>
                            <small class="text-muted"><i class="fas fa-heartbeat me-1"></i>Overall status</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- TOP FORMATIONS SECTION -->
            <div class="row mb-5">
                <div class="col-lg-8">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white border-bottom">
                            <div class="d-flex align-items-center justify-content-between">
                                <h5 class="card-title mb-0">
                                    <i class="fas fa-trophy text-warning me-2"></i>Top 5 Formations by Revenue
                                </h5>
                                <span class="badge bg-warning bg-opacity-10 text-warning">Performance Rank</span>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="bg-light">
                                        <tr>
                                            <th class="text-muted small fw-bold">Rank</th>
                                            <th class="text-muted small fw-bold">Formation Name</th>
                                            <th class="text-muted small fw-bold text-end">Students</th>
                                            <th class="text-muted small fw-bold text-end">Price</th>
                                            <th class="text-muted small fw-bold text-end">Revenue</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for key, formation in metrics.topFormations %}
                                        <tr class="align-middle">
                                            <td>
                                                {% if loop.first %}
                                                    <span class="badge bg-warning" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem;">🥇</span>
                                                {% elseif loop.index == 2 %}
                                                    <span class="badge bg-secondary" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem;">🥈</span>
                                                {% elseif loop.index == 3 %}
                                                    <span class="badge bg-info" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem;">🥉</span>
                                                {% else %}
                                                    <span class="badge bg-light text-dark">{{ loop.index }}</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                <div>
                                                    <strong class="d-block">{{ formation.name }}</strong>
                                                    <small class="text-muted">ID: {{ formation.id }}</small>
                                                </div>
                                            </td>
                                            <td class="text-end">
                                                <span class="badge bg-light text-dark px-3 py-2">{{ formation.enrollments }} students</span>
                                            </td>
                                            <td class="text-end">
                                                <strong>€{{ "%.2f"|format(formation.price) }}</strong>
                                            </td>
                                            <td class="text-end">
                                                <div>
                                                    <strong class="text-success d-block">€{{ "%.2f"|format(formation.revenue) }}</strong>
                                                    <small class="text-muted">{{ loop.index == 1 ? 'Top performer' : 'Good revenue' }}</small>
                                                </div>
                                            </td>
                                        </tr>
                                        {% else %}
                                        <tr>
                                            <td colspan="5" class="text-center text-muted py-4">
                                                <i class="fas fa-inbox me-2"></i>No formations data available yet
                                            </td>
                                        </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SUMMARY CARD -->
                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%);">
                        <div class="card-body p-4">
                            <h5 class="card-title mb-4 fw-bold">
                                <i class="fas fa-chart-bar me-2 text-primary"></i>Platform Summary
                            </h5>
                            <ul class="list-unstyled">
                                <li class="mb-4 pb-3 border-bottom">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="bg-primary bg-opacity-10 p-3 rounded-2" style="min-width: 50px;">
                                            <i class="fas fa-star text-primary fs-6"></i>
                                        </div>
                                        <div>
                                            <small class="text-muted d-block fw-5">BEST PERFORMER</small>
                                            <strong class="text-primary" style="font-size: 0.95rem;">{{ metrics.topFormations[0].name ?? 'N/A' }}</strong>
                                        </div>
                                    </div>
                                </li>
                                <li class="mb-4 pb-3 border-bottom">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="bg-success bg-opacity-10 p-3 rounded-2" style="min-width: 50px;">
                                            <i class="fas fa-users text-success fs-6"></i>
                                        </div>
                                        <div>
                                            <small class="text-muted d-block fw-5">TOTAL STUDENTS</small>
                                            <strong class="text-success">{{ metrics.topFormations|reduce((sum, f) => sum + f.enrollments, 0) }}</strong>
                                        </div>
                                    </div>
                                </li>
                                <li class="mb-4 pb-3 border-bottom">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="bg-info bg-opacity-10 p-3 rounded-2" style="min-width: 50px;">
                                            <i class="fas fa-coins text-info fs-6"></i>
                                        </div>
                                        <div>
                                            <small class="text-muted d-block fw-5">AVG REVENUE</small>
                                            <strong class="text-info">€{{ "%.2f"|format(metrics.topFormations|reduce((sum, f) => sum + f.revenue, 0) / (metrics.topFormations|length ?: 1)) }}</strong>
                                        </div>
                                    </div>
                                </li>
                                <li class="pt-2">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="bg-{% if metrics.avgDropoutRate > 40 %}danger{% else %}success{% endif %} bg-opacity-10 p-3 rounded-2" style="min-width: 50px;">
                                            <i class="fas fa-percent text-{% if metrics.avgDropoutRate > 40 %}danger{% else %}success{% endif %} fs-6"></i>
                                        </div>
                                        <div>
                                            <small class="text-muted d-block fw-5">RETENTION RATE</small>
                                            <strong class="text-{% if metrics.avgDropoutRate > 40 %}danger{% else %}success{% endif %}">{{ (100 - metrics.avgDropoutRate)|round(1) }}%</strong>
                                        </div>
                                    </div>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <!-- AI INSIGHTS SECTION -->
            <div class="row">
                <div class="col-12">
                    <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                        <div class="card-body p-5">
                            <div class="d-flex align-items-start gap-3 mb-4">
                                <div class="p-3 rounded-3" style="background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; min-width: 60px; height: 60px;">
                                    <i class="fas fa-brain fs-4"></i>
                                </div>
                                <div>
                                    <h5 class="mb-1 fw-bold">💡 AI-Powered Business Insights</h5>
                                    <small style="opacity: 0.95;">Powered by Groq AI • Real-time analysis</small>
                                </div>
                            </div>
                            
                            <div class="bg-white bg-opacity-95 rounded-3 p-4 text-dark mb-3">
                                <div class="insight-text" style="line-height: 1.9; color: #333;">
                                    {{ insights|nl2br }}
                                </div>
                            </div>

                            <small class="d-block" style="opacity: 0.95;">
                                <i class="fas fa-info-circle me-2"></i>These insights are generated by advanced AI analysis of your platform data. Use them to guide strategic decisions and optimize performance.
                            </small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- FOOTER INFO -->
            <div class="row mt-5">
                <div class="col-12">
                    <div class="alert alert-light border-1 d-flex align-items-center gap-3" style="background-color: #f8f9fa;">
                        <i class="fas fa-info-circle fs-5 text-info"></i>
                        <div>
                            <strong>Dashboard Information:</strong>
                            <small class="d-block text-muted mt-1">
                                All revenue figures represent transactions from the last 30 days. Student retention is calculated as (100 - dropout rate). Formations ranking is based on total revenue generated. Data refreshes in real-time.
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- Analytics Content END -->
</main>

<style>
    .insight-text {
        line-height: 1.9;
        color: #333;
        font-size: 1.05rem;
    }

    .insight-text p {
        margin-bottom: 1rem;
    }

    .insight-text strong {
        color: #667eea;
        font-weight: 700;
    }

    .card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .card:hover {
        transform: translateY(-3px);
        box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.15) !important;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(102, 126, 234, 0.05);
    }

    .bg-gradient {
        background-image: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
    }

    .border-top-thick {
        border-top: 3px solid #667eea !important;
    }

    @media (max-width: 768px) {
        h1.fs-2 {
            font-size: 1.75rem !important;
        }
        
        h2 {
            font-size: 1.75rem !important;
        }
    }
</style>
{% endblock %}

