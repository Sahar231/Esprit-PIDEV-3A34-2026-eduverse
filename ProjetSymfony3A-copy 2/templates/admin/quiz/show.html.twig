{% extends 'base.html.twig' %}

{% block title %}Quiz Details - {{ quiz.title }}{% endblock %}

{% block body %}
<div class="container mt-5 mb-5">
    <div class="row">
        <div class="col-lg-10 offset-lg-1">
            <!-- Breadcrumb START -->
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb breadcrumb-dark breadcrumb-dots">
                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Home</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('admin_dashboard') }}">Admin Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('admin_quiz_list') }}">All Quizzes</a></li>
                    <li class="breadcrumb-item active">{{ quiz.title }}</li>
                </ol>
            </nav>
            <!-- Breadcrumb END -->

            <!-- Quiz Header -->
            <div class="card mb-4 shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h2 class="mb-1">{{ quiz.title }}</h2>
                            <p class="text-muted mb-0">
                                <i class="bi bi-folder me-2"></i>Formation: 
                                <strong>{{ quiz.formation.title|default('N/A') }}</strong>
                                <i class="bi bi-clock ms-3 me-2"></i>{{ quiz.createdOn|date('M d, Y') }}
                            </p>
                        </div>
                        <div>
                            <span class="badge bg-info fs-6"><i class="bi bi-question-diamond me-1"></i>Quiz</span>
                        </div>
                    </div>

                    <!-- Quiz Meta Info -->
                    <div class="row g-3 mt-3 pt-3 border-top">
                        <div class="col-md-3">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-question-diamond fs-5 text-primary me-2"></i>
                                <div>
                                    <p class="text-muted mb-0 small">Questions</p>
                                    <h6 class="mb-0">{{ quiz.questions|length }}</h6>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-bar-chart fs-5 text-info me-2"></i>
                                <div>
                                    <p class="text-muted mb-0 small">Difficulty</p>
                                    <h6 class="mb-0 text-capitalize">{{ quiz.difficulty }}</h6>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-list-check fs-5 text-warning me-2"></i>
                                <div>
                                    <p class="text-muted mb-0 small">Total Questions</p>
                                    <h6 class="mb-0">{{ quiz.totalQuestions }}</h6>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-percent fs-5 text-success me-2"></i>
                                <div>
                                    <p class="text-muted mb-0 small">Pass Score</p>
                                    <h6 class="mb-0">{{ quiz.passScore }}</h6>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-trophy fs-5 text-primary me-2"></i>
                                <div>
                                    <p class="text-muted mb-0 small">Total Score</p>
                                    <h6 class="mb-0">{{ quiz.totalScore }}</h6>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Questions Section -->
            <div class="card shadow mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-question-diamond me-2"></i>Questions Preview</h5>
                </div>
                <div class="card-body">
                    {% if quiz.questions|length > 0 %}
                        {% for i, question in quiz.questions %}
                            <div class="mb-4 pb-4 {% if not loop.last %}border-bottom{% endif %}">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h6 class="mb-2">
                                        <i class="bi bi-question-circle me-2 text-primary"></i>
                                        Question {{ i + 1 }}
                                    </h6>
                                    <span class="badge bg-secondary">{{ question.score }} points</span>
                                </div>
                                <p class="mb-3 text-dark">{{ question.question }}</p>

                                <div class="ms-3">
                                    <p class="text-muted small mb-2">Answer Choices:</p>
                                    <ul class="list-unstyled">
                                        {% if question.choices %}
                                            {% for choice in question.choices %}
                                                <li class="mb-2">
                                                    {% if choice == question.reply %}
                                                        <span class="badge bg-success me-2"><i class="bi bi-check-circle me-1"></i>Correct</span>
                                                    {% else %}
                                                        <i class="bi bi-circle me-2 text-secondary"></i>
                                                    {% endif %}
                                                    {{ choice }}
                                                </li>
                                            {% endfor %}
                                        {% else %}
                                            <li class="text-muted"><em>No choices available</em></li>
                                        {% endif %}
                                    </ul>
                                </div>
                            </div>
                        {% endfor %}
                    {% else %}
                        <div class="alert alert-warning mb-0">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            No questions in this quiz yet!
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="text-end mt-4">
                <a href="{{ path('admin_quiz_list') }}" class="btn btn-secondary btn-lg">
                    <i class="bi bi-arrow-left me-2"></i>Back to Quizzes
                </a>
            </div>

            <!-- Return to Dashboard Button -->
            <div class="mt-4">
                <a href="{{ path('admin_dashboard') }}" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Return to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
