						</div>
					{% endif %}
					<form method="POST" enctype="multipart/form-data">
						<div class="mb-3">
							<label class="form-label">Formation Title</label>
							<input type="text" class="form-control" name="title" value="{{ formation.title }}" required>
						</div>
						<div class="mb-3">
							<div class="d-flex justify-content-between align-items-center mb-2">
								<label class="form-label mb-0">Description</label>
								{% if aiEnabled %}
									<button type="button" class="btn btn-sm btn-purple mb-0" id="btn-gen-ai-form-adm-edit">
										<i class="fas fa-magic me-2"></i>âœ¨ GÃ©nÃ©rer une description
									</button>
								{% else %}
									<button type="button" class="btn btn-sm btn-secondary mb-0" disabled title="Groq API key not configured. To enable AI-powered description generation, set GROQ_API_KEY in .env">
										<i class="fas fa-ban me-2"></i>AI Disabled
									</button>
								{% endif %}
							</div>
							<textarea class="form-control" id="formationDescriptionEdit" name="description" rows="4" required>{{ formation.description }}</textarea>
						</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const genBtn = document.getElementById('btn-gen-ai-form-adm-edit');
    if (genBtn) {
        genBtn.addEventListener('click', async () => {
            const titleInput = document.querySelector('input[name="title"]');
            const descTextarea = document.getElementById('formationDescriptionEdit');
            
            if (!titleInput || !titleInput.value.trim()) {
                alert('Veuillez d\'abord saisir un titre.');
                return;
            }

            genBtn.disabled = true;
            genBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>GÃ©nÃ©ration...';

            try {
                const response = await fetch('{{ path("api_generate_description") }}', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title: titleInput.value, entityType: 'formation' })
                });

                const data = await response.json();
                if (data.description) {
                    descTextarea.value = data.description;
                } else {
                    alert('Erreur: ' + (data.error || 'Impossible de gÃ©nÃ©rer la description.'));
                }
            } catch (error) {
                console.error('AI Error:', error);
                alert('Une erreur est survenue.');
            } finally {
                genBtn.disabled = false;
                genBtn.innerHTML = '<i class="fas fa-magic me-2"></i>âœ¨ GÃ©nÃ©rer une description';
            }
        });
    }
});
</script>
						<div class="row">
