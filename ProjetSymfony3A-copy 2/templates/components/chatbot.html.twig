{# Chatbot Widget Component #}
<div id="chatbot-widget" class="chatbot-container">
    <!-- Chatbot Toggle Button -->
    <button id="chatbot-toggle" class="chatbot-toggle" title="Open Chatbot">
        <i class="fas fa-robot"></i>
        <span class="chatbot-badge">AI</span>
    </button>

    <!-- Chatbot Panel -->
    <div id="chatbot-panel" class="chatbot-panel d-none">
        <!-- Header -->
        <div class="chatbot-header">
            <h5 class="mb-0">
                <i class="fas fa-robot me-2"></i>Quiz Assistant
            </h5>
            <button id="chatbot-close" class="btn-close" type="button" aria-label="Close chatbot"></button>
        </div>

        <!-- Messages Container -->
        <div id="chatbot-messages" class="chatbot-messages">
            <div class="chatbot-message bot-message">
                <div class="message-content">
                    <p>👋 Hi! I'm your quiz assistant. Select a question and ask me anything about it!</p>
                </div>
            </div>
        </div>

        <!-- Selected Question Display -->
        <div id="selected-question-display" class="selected-question d-none">
            <div style="background: linear-gradient(135deg, #e7f3ff 0%, #f0f8ff 100%); padding: 12px; border-radius: 6px; border-left: 4px solid #667eea;">
                <small class="text-muted d-block mb-2">
                    <i class="fas fa-check-circle text-success me-1"></i>Selected Question:
                </small>
                <p id="selected-question-text" class="mb-0 small fw-bold" style="color: #333;"></p>
            </div>
        </div>

        <!-- Input Area -->
        <div class="chatbot-input-area">
            <div class="input-group">
                <input 
                    id="chatbot-input" 
                    type="text" 
                    class="form-control chatbot-input" 
                    placeholder="Ask about this question..." 
                    disabled
                />
                <button 
                    id="chatbot-send" 
                    class="btn btn-primary" 
                    type="button" 
                    disabled
                    title="Send message"
                >
                    <i class="fas fa-paper-plane"></i>
                </button>
            </div>
            <small class="text-muted d-block mt-2">
                <i class="fas fa-info-circle"></i> Select a question first
            </small>
        </div>
    </div>
</div>

<style>
    .chatbot-container {
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 1000;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .chatbot-toggle {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
        transition: all 0.3s ease;
        position: relative;
    }

    .chatbot-toggle:hover {
        transform: scale(1.1);
        box-shadow: 0 6px 16px rgba(102, 126, 234, 0.6);
    }

    .chatbot-badge {
        position: absolute;
        top: -5px;
        right: -5px;
        background: #28a745;
        color: white;
        border-radius: 50%;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: bold;
        border: 2px solid white;
    }

    .chatbot-panel {
        position: absolute;
        bottom: 80px;
        right: 0;
        width: 380px;
        max-height: 600px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 5px 30px rgba(0, 0, 0, 0.15);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        animation: slideUp 0.3s ease;
    }

    @keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .chatbot-panel.d-none {
        display: none;
    }

    .chatbot-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 15px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .chatbot-header h5 {
        color: white;
    }

    .chatbot-header .btn-close {
        filter: brightness(0) invert(1);
        opacity: 0.7;
        transition: opacity 0.2s ease;
    }

    .chatbot-header .btn-close:hover {
        opacity: 1;
    }

    .chatbot-messages {
        flex: 1;
        overflow-y: auto;
        padding: 15px;
        background-color: #f8f9fa;
        min-height: 250px;
    }

    .chatbot-message {
        margin-bottom: 12px;
        display: flex;
        animation: fadeIn 0.3s ease;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .bot-message {
        justify-content: flex-start;
    }

    .user-message {
        justify-content: flex-end;
    }

    .message-content {
        max-width: 85%;
        padding: 10px 12px;
        border-radius: 8px;
        word-wrap: break-word;
    }

    .bot-message .message-content {
        background-color: #e9ecef;
        color: #333;
        border-bottom-left-radius: 2px;
    }

    .user-message .message-content {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-bottom-right-radius: 2px;
    }

    .message-content p {
        margin: 0;
        font-size: 14px;
        line-height: 1.4;
    }

    .selected-question {
        background-color: #e7f3ff;
        padding: 10px 12px;
        border-left: 4px solid #667eea;
        font-size: 12px;
    }

    #selected-question-text {
        color: #333;
        margin-top: 5px;
        font-weight: 500;
    }

    .chatbot-input-area {
        padding: 12px;
        background-color: white;
        border-top: 1px solid #e0e0e0;
    }

    .chatbot-input {
        border-radius: 6px;
        border: 1px solid #ddd;
        font-size: 14px;
    }

    .chatbot-input:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    .chatbot-input:disabled {
        background-color: #f5f5f5;
        cursor: not-allowed;
        opacity: 0.6;
    }

    #chatbot-send {
        border-radius: 6px;
        padding: 0 15px;
    }

    #chatbot-send:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .typing-indicator {
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 10px 12px;
        background-color: #e9ecef;
        border-radius: 8px;
        width: fit-content;
    }

    .typing-dot {
        width: 8px;
        height: 8px;
        background-color: #999;
        border-radius: 50%;
        animation: typing 1.4s infinite;
    }

    .typing-dot:nth-child(2) {
        animation-delay: 0.2s;
    }

    .typing-dot:nth-child(3) {
        animation-delay: 0.4s;
    }

    @keyframes typing {
        0%, 60%, 100% {
            opacity: 0.6;
            transform: translateY(0);
        }
        30% {
            opacity: 1;
            transform: translateY(-10px);
        }
    }

    /* Responsive */
    @media (max-width: 576px) {
        .chatbot-panel {
            width: calc(100vw - 40px);
            max-height: 70vh;
        }

        .chatbot-container {
            bottom: 10px;
            right: 10px;
        }
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const chatbotToggle = document.getElementById('chatbot-toggle');
    const chatbotPanel = document.getElementById('chatbot-panel');
    const chatbotClose = document.getElementById('chatbot-close');
    const chatbotInput = document.getElementById('chatbot-input');
    const chatbotSend = document.getElementById('chatbot-send');
    const chatbotMessages = document.getElementById('chatbot-messages');
    const selectedQuestionDisplay = document.getElementById('selected-question-display');
    const selectedQuestionText = document.getElementById('selected-question-text');
    let selectedQuestion = null;

    // Toggle chatbot panel
    chatbotToggle.addEventListener('click', function() {
        chatbotPanel.classList.toggle('d-none');
        if (!chatbotPanel.classList.contains('d-none')) {
            chatbotInput.focus();
        }
    });

    // Close chatbot
    chatbotClose.addEventListener('click', function() {
        chatbotPanel.classList.add('d-none');
    });

    // Question selection - works for quiz questions
    document.addEventListener('click', function(e) {
        // Check if clicked element or its parent has data-quiz-question attribute
        let questionElement = e.target.closest('[data-quiz-question]');
        
        if (questionElement) {
            // Get question text from data attribute
            selectedQuestion = questionElement.getAttribute('data-quiz-question');
            updateSelectedQuestion();
            
            // Visual feedback - highlight selected question
            document.querySelectorAll('[data-quiz-question]').forEach(el => {
                el.style.borderColor = '';
                el.style.boxShadow = '';
            });
            questionElement.style.borderColor = '#667eea';
            questionElement.style.boxShadow = '0 0 15px rgba(102, 126, 234, 0.5)';
        }
    });

    function updateSelectedQuestion() {
        if (selectedQuestion) {
            selectedQuestionText.textContent = selectedQuestion.substring(0, 100) + 
                (selectedQuestion.length > 100 ? '...' : '');
            selectedQuestionDisplay.classList.remove('d-none');
            chatbotInput.disabled = false;
            chatbotSend.disabled = false;
            chatbotInput.placeholder = 'Ask about this question...';
        } else {
            selectedQuestionDisplay.classList.add('d-none');
            chatbotInput.disabled = true;
            chatbotSend.disabled = true;
            chatbotInput.placeholder = 'Select a question first...';
        }
    }

    // Send message
    function sendMessage() {
        const message = chatbotInput.value.trim();
        if (!message || !selectedQuestion) return;

        // Add user message
        addMessage(message, 'user');
        chatbotInput.value = '';

        // Disable send button while waiting
        chatbotSend.disabled = true;

        // Show typing indicator
        showTypingIndicator();

        // Send to API
        fetch('/api/chatbot/ask', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '',
            },
            body: JSON.stringify({
                question: message,
                context: selectedQuestion,
            })
        })
        .then(response => {
            removeTypingIndicator();
            
            if (!response.ok) {
                return response.json().then(data => {
                    throw new Error(data.error || 'HTTP ' + response.status + ' error');
                });
            }
            
            return response.json();
        })
        .then(data => {
            if (data.success && data.answer) {
                addMessage(data.answer, 'bot');
            } else if (data.error) {
                addMessage('❌ Error: ' + data.error, 'bot');
                console.error('Chatbot API error:', data.error);
            } else {
                addMessage('Sorry, I could not understand the response from the chatbot service.', 'bot');
            }
        })
        .catch(error => {
            removeTypingIndicator();
            console.error('Chatbot fetch error:', error);
            addMessage('❌ Connection error: ' + error.message + '. Please check your internet connection or try again later.', 'bot');
        })
        .finally(() => {
            // Re-enable send button if question still selected
            if (selectedQuestion) {
                chatbotSend.disabled = false;
                chatbotInput.focus();
            }
        });
    }

    chatbotSend.addEventListener('click', sendMessage);
    chatbotInput.addEventListener('keypress', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    function addMessage(text, sender) {
        const messageDiv = document.createElement('div');
        messageDiv.className = 'chatbot-message ' + (sender === 'bot' ? 'bot-message' : 'user-message');
        
        const contentDiv = document.createElement('div');
        contentDiv.className = 'message-content';
        
        const p = document.createElement('p');
        p.textContent = text;
        
        contentDiv.appendChild(p);
        messageDiv.appendChild(contentDiv);
        chatbotMessages.appendChild(messageDiv);
        
        // Scroll to bottom
        chatbotMessages.scrollTop = chatbotMessages.scrollHeight;
    }

    function showTypingIndicator() {
        const messageDiv = document.createElement('div');
        messageDiv.className = 'chatbot-message bot-message';
        messageDiv.id = 'typing-indicator';
        
        const contentDiv = document.createElement('div');
        contentDiv.className = 'typing-indicator';
        contentDiv.innerHTML = '<div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div>';
        
        messageDiv.appendChild(contentDiv);
        chatbotMessages.appendChild(messageDiv);
        chatbotMessages.scrollTop = chatbotMessages.scrollHeight;
    }

    function removeTypingIndicator() {
        const indicator = document.getElementById('typing-indicator');
        if (indicator) {
            indicator.remove();
        }
    }
});
</script>
