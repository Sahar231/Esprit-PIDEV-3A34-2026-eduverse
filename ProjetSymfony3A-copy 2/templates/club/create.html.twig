{% extends 'base.html.twig' %}

{% block title %}Create Club{% endblock %}

{% block stylesheets %}
<style>
    .form-error-messages ul {
        list-style: none;
        padding: 0;
        margin: 0;
        color: #dc3545;
        font-size: 0.875em;
        font-weight: bold;
    }
</style>
{% endblock %}

{% block body %}
<main>
<section class="bg-dark align-items-center d-flex" style="background: url({{ asset('assets/images/pattern/04.png') }}) no-repeat center center; background-size: cover;">
	<div class="container">
		<div class="row">
			<div class="col-12">
				<h1 class="text-white">Create a New Club</h1>
				<nav aria-label="breadcrumb">
					<ol class="breadcrumb breadcrumb-dark breadcrumb-dots mb-0">
						<li class="breadcrumb-item"><a href="{{ path("app_home") }}">Home</a></li>
						<li class="breadcrumb-item"><a href="{{ path("club_list") }}">Clubs</a></li>
						<li class="breadcrumb-item active">Create</li>
					</ol>
				</nav>
			</div>
		</div>
	</div>
</section>

<section class="py-5">
	<div class="container">
		<div class="row">
			<div class="col-lg-8 mx-auto">
				<div class="card shadow">
					<div class="card-body p-5">
						<h3 class="mb-4"><i class="fas fa-plus-circle me-2"></i>Create a New Club</h3>

						<p class="text-muted mb-4">
							Create a club for your group, interests, or activities. Your club will be pending approval from administrators.
						</p>

						{{ form_start(form, {'action': path('club_create'), 'attr': {'class': 'row g-3'}}) }}
							<div class="col-12">
								{{ form_label(form.name, null, {'label_attr': {'class': 'form-label'}}) }}
								<div class="form-error-messages">
									{{ form_errors(form.name) }}
								</div>
								{{ form_widget(form.name) }}
								<small class="form-text text-muted">Minimum 3 caractères</small>
							</div>

							<div class="col-12">
								{{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}
								<div class="form-error-messages">
									{{ form_errors(form.description) }}
								</div>
								{{ form_widget(form.description, {attr: {class: 'form-control', rows: 6}}) }}
								<button type="button" class="btn btn-outline-primary btn-sm mt-2" onclick="generateDescription(this)">
									✨ Générer une description
								</button>
								<small class="form-text text-muted d-block mt-2">Donnez une description détaillée de votre club</small>
							</div>

							<div class="col-12">
								<div class="alert alert-info">
									<i class="fas fa-info-circle me-2"></i>
									<strong>Note :</strong> Votre club sera en <strong>statut en attente</strong> jusqu'à ce qu'il soit approuvé par un administrateur.
								</div>
							</div>

							<div class="col-12">
								<div class="d-grid gap-2 d-sm-flex">
									<button type="submit" class="btn btn-primary btn-lg">
										<i class="fas fa-check me-2"></i>Créer le Club
									</button>
									<a href="{{ path('club_list') }}" class="btn btn-secondary btn-lg">
										<i class="fas fa-times me-2"></i>Annuler
									</a>
								</div>
							</div>
						{{ form_end(form) }}
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
</main>

<!-- Script for generating club description -->
<script>
async function generateDescription(btn) {
    const form = btn.closest('form');
    if (!form) {
        alert('Erreur: Formulaire non trouvé');
        return;
    }
    
    // Find name field in club form (name attribute is "club[name]")
    const nameField = form.querySelector('input[name*="name"]');
    const descField = form.querySelector('textarea[name*="description"]');
    
    if (!nameField || !descField) {
        alert('Erreur: Champs du formulaire non trouvés. Vérifiez la structure du formulaire.');
        console.error('Name field:', nameField);
        console.error('Desc field:', descField);
        return;
    }
    
    const nameValue = nameField.value.trim();
    
    if (!nameValue) {
        alert('Veuillez remplir le nom du club en premier !');
        nameField.focus();
        return;
    }
    
    btn.disabled = true;
    const originalContent = btn.innerHTML;
    btn.innerHTML = '⏳ Génération en cours...';
    
    try {
        console.log('Sending request with:', { name: nameValue, entityType: 'club' });
        
        const response = await fetch('/api/generate-description', {
            method: 'POST',
            headers: { 
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({ 
                name: nameValue, 
                entityType: 'club' 
            })
        });
        
        console.log('Response status:', response.status);
        const data = await response.json();
        console.log('Response data:', data);
        
        if (!response.ok) {
            throw new Error(data.error || 'Erreur du serveur');
        }
        
        if (data.description) {
            descField.value = data.description;
            descField.dispatchEvent(new Event('input', { bubbles: true }));
        } else if (data.error) {
            alert('Erreur: ' + data.error);
        }
    } catch(e) {
        console.error('Error:', e);
        alert('Erreur lors de la génération: ' + e.message);
    } finally {
        btn.disabled = false;
        btn.innerHTML = originalContent;
    }
}
</script>
{% endblock %}
