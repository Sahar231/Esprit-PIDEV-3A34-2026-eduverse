{% extends "base.html.twig" %}

{% block title %}Wallet{% endblock %}

{% block body %}
<div class="container-fluid px-4 py-5">
    <!-- Content START -->
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card border-0 shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-wallet2 me-2"></i>My Wallet</h4>
                </div>
                <div class="card-body">
                    {% if wallet %}
                        <!-- Wallet Details -->
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <div class="card bg-light">
                                    <div class="card-body">
                                        <h6 class="card-title">Account Holder</h6>
                                        <p class="card-text mb-0">
                                            <strong>{{ wallet.user.fullName }}</strong>
                                        </p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card bg-success text-white">
                                    <div class="card-body">
                                        <h6 class="card-title">Current Balance</h6>
                                        <p class="card-text mb-0">
                                            <strong class="fs-4">{{ wallet.balance }} Credits</strong>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Wallet Info -->
                        <div class="row mb-4">
                            <div class="col-md-12">
                                <p class="text-muted small">
                                    <i class="bi bi-calendar me-2"></i>
                                    Created: {{ wallet.createdAt|date('d/m/Y H:i') }}<br>
                                    <i class="bi bi-arrow-repeat me-2"></i>
                                    Last Updated: {{ wallet.updatedAt|date('d/m/Y H:i') }}
                                </p>
                            </div>
                        </div>

                        <!-- Add Credits Section -->
                        <div class="card bg-light border-primary border-2 mb-4">
                            <div class="card-header bg-primary text-white">
                                <h6 class="mb-0"><i class="bi bi-credit-card me-2"></i>Add Credits</h6>
                            </div>
                            <div class="card-body">
                                <p class="small text-muted mb-3">
                                    1 credit = 1 euro. Select the number of credits you want to purchase.
                                </p>
                                
                                <form method="POST" action="{{ path('student_wallet_checkout') }}" id="checkoutForm">
                                    <div class="row mb-3">
                                        <div class="col-md-8">
                                            <label for="creditsInput" class="form-label">Number of Credits</label>
                                            <div class="input-group">
                                                <input 
                                                    type="number" 
                                                    class="form-control" 
                                                    id="creditsInput"
                                                    name="credits"
                                                    min="1"
                                                    max="1000"
                                                    value="10"
                                                    required
                                                    aria-describedby="priceHint"
                                                >
                                                <span class="input-group-text">Credits</span>
                                            </div>
                                            <small id="priceHint" class="form-text text-muted d-block mt-1">
                                                Min: 1 | Max: 1000 | Total: <strong id="totalPrice">€10.00</strong>
                                            </small>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label">&nbsp;</label>
                                            <button type="submit" class="btn btn-success w-100" id="checkoutBtn">
                                                <i class="bi bi-credit-card me-2"></i>Pay with Stripe
                                            </button>
                                        </div>
                                    </div>
                                </form>

                                <script>
                                document.getElementById('creditsInput').addEventListener('change', function() {
                                    const credits = parseInt(this.value) || 0;
                                    const price = (credits * 1).toFixed(2);
                                    document.getElementById('totalPrice').textContent = '€' + price;
                                });
                                </script>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="d-flex gap-2">
                            <a href="{{ path('student_wallet_edit', {id: wallet.id}) }}" class="btn btn-primary">
                                <i class="bi bi-pencil me-2"></i>Edit Wallet
                            </a>
                            <form method="POST" action="{{ path('student_wallet_delete', {id: wallet.id}) }}" style="display:inline;" 
                                  onsubmit="return confirm('Are you sure you want to delete your wallet? This action cannot be undone.');">
                                <button type="submit" class="btn btn-danger">
                                    <i class="bi bi-trash me-2"></i>Delete Wallet
                                </button>
                            </form>
                            <a href="{{ path('student_dashboard') }}" class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
                            </a>
                        </div>
                    {% else %}
                        <!-- No Wallet Message -->
                        <div class="text-center py-5">
                            <i class="bi bi-wallet2 text-muted" style="font-size: 4rem;"></i>
                            <h5 class="mt-3 mb-3">No Wallet Yet</h5>
                            <p class="text-muted mb-4">Create your wallet to start managing your credits and payments.</p>
                            <a href="{{ path('student_wallet_create') }}" class="btn btn-primary">
                                <i class="bi bi-plus-circle me-2"></i>Create Wallet
                            </a>
                            <a href="{{ path('student_dashboard') }}" class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
    <!-- Content END -->
</div>
{% endblock %}
