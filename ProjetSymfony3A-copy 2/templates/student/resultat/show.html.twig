{% extends 'base.html.twig' %}

{% block title %}Quiz Result - {{ quiz.title }}{% endblock %}

{% block body %}
<main>
    <!-- Page Banner START -->
    <section class="pt-0">
        <div class="container-fluid px-0">
            <div class="card bg-blue h-100px h-md-200px rounded-0" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);"></div>
        </div>
        <div class="container mt-n4 mb-4">
            <div class="row">
                <div class="col-12">
                    <div class="card bg-transparent card-body pb-0 px-0">
                        <div class="d-flex align-items-center justify-content-between flex-wrap">
                            <div>
                                <h1 class="fs-2 mb-1">
                                    <i class="fas fa-certificate me-2"></i>{{ quiz.title }}
                                </h1>
                                <p class="text-body mb-0">Result Details • Completed: <strong>{{ resultat.createdAt|date('M d, Y H:i') }}</strong></p>
                            </div>
                            <div class="mt-3 mt-md-0 d-flex gap-2">
                                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="window.history.back();" title="Back to results">
                                    <i class="fas fa-arrow-left me-1"></i>Back
                                </button>
                                <a href="{{ path('student_resultat_pdf', {id: resultat.id}) }}" class="btn btn-sm btn-success" title="Download as PDF">
                                    <i class="fas fa-download me-1"></i>Download PDF
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- Page Banner END -->

    <!-- Content START -->
    <section class="py-5">
        <div class="container">
            <div class="row g-4">
                <!-- Score Card -->
                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm h-100 position-relative overflow-hidden">
                        <div class="position-absolute top-0 end-0 w-25 h-25 bg-success bg-opacity-5 rounded-3"></div>
                        <div class="card-body p-4 position-relative text-center">
                            <h6 class="card-title mb-3 fw-bold text-muted">YOUR SCORE</h6>
                            <div style="font-size: 48px; font-weight: bold; color: #667eea; margin-bottom: 10px;">
                                {{ resultat.score }}/{{ quiz.questions|length }}
                            </div>
                            {% set percentage = (resultat.score / quiz.questions|length * 100)|round(2) %}
                            {% set statusClass = percentage >= 70 ? 'success' : (percentage >= 50 ? 'warning' : 'danger') %}
                            <div style="font-size: 24px; color: #{{ statusClass }};">
                                {{ percentage }}%
                            </div>
                            <div class="mt-3">
                                <span class="badge bg-{{ statusClass }}">
                                    {% if percentage >= 70 %}
                                        <i class="fas fa-check-circle me-1"></i>Excellent
                                    {% elseif percentage >= 50 %}
                                        <i class="fas fa-exclamation-circle me-1"></i>Good
                                    {% else %}
                                        <i class="fas fa-times-circle me-1"></i>Review Needed
                                    {% endif %}
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Stats -->
                <div class="col-lg-8">
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-info bg-opacity-10 p-3 rounded-2" style="width: 50px; height: 50px; display: flex; align-items: center; justify-content: center;">
                                            <i class="fas fa-list text-info fs-5"></i>
                                        </div>
                                        <div class="ms-3">
                                            <h6 class="mb-1 fw-bold">Total Questions</h6>
                                            <h5 class="mb-0">{{ quiz.questions|length }}</h5>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-success bg-opacity-10 p-3 rounded-2" style="width: 50px; height: 50px; display: flex; align-items: center; justify-content: center;">
                                            <i class="fas fa-check text-success fs-5"></i>
                                        </div>
                                        <div class="ms-3">
                                            <h6 class="mb-1 fw-bold">Correct Answers</h6>
                                            <h5 class="mb-0">{{ resultat.score }}</h5>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-danger bg-opacity-10 p-3 rounded-2" style="width: 50px; height: 50px; display: flex; align-items: center; justify-content: center;">
                                            <i class="fas fa-times text-danger fs-5"></i>
                                        </div>
                                        <div class="ms-3">
                                            <h6 class="mb-1 fw-bold">Wrong Answers</h6>
                                            <h5 class="mb-0">{{ quiz.questions|length - resultat.score }}</h5>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-warning bg-opacity-10 p-3 rounded-2" style="width: 50px; height: 50px; display: flex; align-items: center; justify-content: center;">
                                            <i class="fas fa-bookmark text-warning fs-5"></i>
                                        </div>
                                        <div class="ms-3">
                                            <h6 class="mb-1 fw-bold">Difficulty</h6>
                                            <h5 class="mb-0">{{ quiz.level|upper }}</h5>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Answers Details -->
            <div class="row mt-5">
                <div class="col-12">
                    <h3 class="mb-4"><i class="fas fa-list-check me-2"></i>Answer Details</h3>
                    
                    {% if answers|length > 0 %}
                        <div class="alert alert-info alert-sm mb-3" role="alert">
                            <i class="fas fa-lightbulb me-2"></i>
                            <strong>Tip:</strong> Click on any question row to select it and ask the chatbot for clarification!
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th scope="col" style="width: 5%;">#</th>
                                        <th scope="col" style="width: 40%;">Question</th>
                                        <th scope="col" style="width: 25%;">Your Answer</th>
                                        <th scope="col" style="width: 25%;">Correct Answer</th>
                                        <th scope="col" style="width: 5%;">Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for index, answer in answers %}
                                        <tr class="question-item" data-quiz-question="{{ answer.question_text|default('N/A') }}" style="cursor: pointer; transition: all 0.3s ease;" 
                                            onmouseover="this.style.backgroundColor='#e7f3ff'; this.style.boxShadow='0 0 10px rgba(102, 126, 234, 0.2)';" 
                                            onmouseout="this.style.backgroundColor=''; this.style.boxShadow='';">
                                            <td><strong>{{ index + 1 }}</strong></td>
                                            <td>{{ answer.question_text|default('N/A') }}</td>
                                            <td>
                                                <span class="badge bg-light text-dark">{{ answer.selected_choice|default('Not answered') }}</span>
                                            </td>
                                            <td>
                                                <span class="badge bg-light text-dark">{{ answer.correct_choice|default('N/A') }}</span>
                                            </td>
                                            <td>
                                                {% if answer.is_correct %}
                                                    <span class="badge bg-success">
                                                        <i class="fas fa-check me-1"></i>Correct
                                                    </span>
                                                {% else %}
                                                    <span class="badge bg-danger">
                                                        <i class="fas fa-times me-1"></i>Wrong
                                                    </span>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <div class="alert alert-info" role="alert">
                            <i class="fas fa-info-circle me-2"></i>
                            No detailed answers available for this quiz attempt.
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </section>
    <!-- Content END -->
</main>

<!-- Include Chatbot Component -->
{{ include('components/chatbot.html.twig') }}

{% endblock %}
