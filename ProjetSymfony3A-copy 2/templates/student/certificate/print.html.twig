{% extends 'base.html.twig' %}

{% block title %}{{ certificate.formation.title }} - Certificate{% endblock %}

{% block body %}
<div class="container-fluid" style="background-color: #f5f5f5; padding: 20px 0;">
    <!-- Toolbar - Only visible on screen, hidden when printing -->
    <div style="padding: 20px; background-color: white; border-bottom: 1px solid #ddd; margin-bottom: 20px;">
        <div class="container-lg d-flex justify-content-between align-items-center">
            <h2 class="mb-0">Certificate</h2>
            <div class="btn-group">
                <a href="{{ path('student_certificate_download', {id: certificate.id}) }}" class="btn btn-primary btn-sm">
                    <i class="fas fa-download me-2"></i>Download PDF
                </a>
                <button class="btn btn-secondary btn-sm" onclick="window.print()">
                    <i class="fas fa-print me-2"></i>Print
                </button>
                <a href="{{ path('student_certificate_show', {id: certificate.id}) }}" class="btn btn-outline-secondary btn-sm">
                    <i class="fas fa-arrow-left me-2"></i>Back
                </a>
            </div>
        </div>
    </div>

    <!-- Certificate Display -->
    <div class="container-lg">
        <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; min-height: 600px;">
            <div style="background: white; padding: 60px; border-radius: 8px; width: 100%; max-width: 900px; text-align: center;">
                <!-- Header -->
                <div style="margin-bottom: 40px; border-bottom: 3px solid #667eea; padding-bottom: 20px;">
                    <div style="font-size: 4rem; color: #667eea; margin-bottom: 20px;">
                        <i class="fas fa-medal"></i>
                    </div>
                    <h1 style="font-size: 2rem; color: #667eea; font-weight: 300; letter-spacing: 2px; margin: 0;">
                        CERTIFICATE OF COMPLETION
                    </h1>
                </div>

                <!-- Main Content -->
                <p style="font-size: 1rem; color: #666; margin-bottom: 10px;">This Certifies That</p>

                <div style="font-size: 2.2rem; font-weight: 600; color: #333; border-bottom: 2px solid #667eea; padding: 20px 0; margin: 30px 0;">
                    {{ app.user.fullName }}
                </div>

                <p style="font-size: 1.1rem; color: #666; margin-bottom: 15px;">
                    has successfully completed the professional training program
                </p>

                <div style="font-size: 1.8rem; font-weight: 600; color: #333; border-bottom: 2px solid #667eea; padding: 20px 0; margin-bottom: 30px;">
                    {{ certificate.formation.title }}
                </div>

                <!-- Details Grid -->
                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin: 30px 0; padding: 20px 0; border-top: 2px solid #667eea; border-bottom: 2px solid #667eea;">
                    <div>
                        <small style="font-size: 0.85rem; color: #999; text-transform: uppercase; letter-spacing: 1px;">Level</small>
                        <p style="font-size: 1.3rem; font-weight: 600; color: #333; margin: 5px 0;">{{ certificate.formation.level ?? 'Standard' }}</p>
                    </div>
                    <div>
                        <small style="font-size: 0.85rem; color: #999; text-transform: uppercase; letter-spacing: 1px;">Duration</small>
                        <p style="font-size: 1.3rem; font-weight: 600; color: #333; margin: 5px 0;">
                            {% if certificate.formation.duration %}
                                {{ certificate.formation.duration }}
                                {% if certificate.formation.duration == 1 %}week{% else %}weeks{% endif %}
                            {% else %}
                                Self-Paced
                            {% endif %}
                        </p>
                    </div>
                    <div>
                        <small style="font-size: 0.85rem; color: #999; text-transform: uppercase; letter-spacing: 1px;">Score</small>
                        <p style="font-size: 1.3rem; font-weight: 600; color: #333; margin: 5px 0;">{{ certificate.score|round(2) }}%</p>
                    </div>
                </div>

                <!-- Signatures -->
                <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 40px; margin-top: 40px; padding-top: 30px; border-top: 2px solid #667eea;">
                    <div style="text-align: center;">
                        <div style="border-top: 2px solid #333; height: 60px; margin-bottom: 10px;"></div>
                        <small style="font-size: 0.85rem; color: #666; font-weight: 500;">
                            <strong>Authorized Signature</strong>
                        </small>
                    </div>
                    <div style="text-align: center;">
                        <div style="border-top: 2px solid #333; height: 60px; margin-bottom: 10px;"></div>
                        <small style="font-size: 0.85rem; color: #666; font-weight: 500;">
                            <strong>{{ certificate.awardedAt|date('F d, Y') }}</strong><br>
                            <small>Date Awarded</small>
                        </small>
                    </div>
                </div>

                <p style="margin-top: 40px; color: #999; font-size: 0.85rem;">
                    This certificate is earned through successful completion of coursework and assessments.
                </p>

                <div style="margin-top: 20px; color: #ccc; font-size: 0.8rem;">
                    Certificate ID: {{ certificate.id }}
                </div>
            </div>
        </div>
    </div>

    <!-- Info Alert -->
    <div class="container-lg" style="margin-top: 20px;">
        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i>
            <strong>Tip:</strong> Click "Print" to open the print dialog, then choose:
            <ul style="margin-top: 10px; margin-bottom: 0;">
                <li><strong>Print to Paper:</strong> Select your printer and print</li>
                <li><strong>Save as PDF:</strong> Choose "Save as PDF" as destination instead of a printer</li>
            </ul>
        </div>
    </div>
</div>

<style>
    @media print {
        body {
            background-color: white;
            margin: 0;
            padding: 0;
        }
        
        /* Hide toolbar when printing */
        div[style*="padding: 20px; background-color: white"] {
            display: none !important;
        }
        
        .alert {
            display: none !important;
        }
        
        /* Optimize container for print */
        .container-fluid,
        .container-lg {
            background-color: white;
            padding: 0 !important;
        }
    }
</style>
{% endblock %}
