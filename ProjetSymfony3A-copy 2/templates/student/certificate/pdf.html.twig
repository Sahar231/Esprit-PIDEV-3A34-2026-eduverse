<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ certificate.formation.title }} - Certificate</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: white;
            padding: 0;
        }

        .certificate-page {
            width: 100%;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            page-break-after: always;
        }

        .certificate-container {
            width: 90%;
            max-width: 1100px;
            background: white;
            padding: 60px;
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
            border: 3px solid #667eea;
        }

        .certificate-content {
            text-align: center;
            color: #333;
        }

        .certificate-header {
            margin-bottom: 40px;
            border-bottom: 3px solid #667eea;
            padding-bottom: 20px;
        }

        .icon-badge {
            font-size: 5rem;
            color: #667eea;
            margin-bottom: 20px;
        }

        .certificate-title {
            font-size: 2rem;
            color: #667eea;
            font-weight: 300;
            margin-bottom: 20px;
            letter-spacing: 2px;
        }

        .subtitle {
            font-size: 1rem;
            color: #666;
            margin-bottom: 10px;
        }

        .student-name {
            font-size: 2.2rem;
            font-weight: 600;
            color: #333;
            border-bottom: 2px solid #667eea;
            padding-bottom: 15px;
            margin: 30px 0;
            min-height: 80px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .achievement-text {
            font-size: 1.1rem;
            color: #666;
            margin-bottom: 15px;
        }

        .formation-title {
            font-size: 1.8rem;
            font-weight: 600;
            color: #333;
            border-bottom: 2px solid #667eea;
            padding-bottom: 15px;
            margin-bottom: 30px;
            min-height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .details-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin: 30px 0;
            padding: 20px 0;
            border-top: 2px solid #667eea;
            border-bottom: 2px solid #667eea;
        }

        .detail-item {
            padding: 10px;
        }

        .detail-label {
            font-size: 0.85rem;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }

        .detail-value {
            font-size: 1.3rem;
            font-weight: 600;
            color: #333;
        }

        .signatures-section {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 40px;
            margin-top: 40px;
            padding-top: 30px;
            border-top: 2px solid #667eea;
        }

        .signature-block {
            text-align: center;
        }

        .signature-line {
            border-top: 2px solid #333;
            height: 60px;
            margin-bottom: 10px;
        }

        .signature-label {
            font-size: 0.85rem;
            color: #666;
            font-weight: 500;
        }

        .footer-text {
            margin-top: 40px;
            color: #999;
            font-size: 0.85rem;
        }

        .certificate-id {
            margin-top: 20px;
            color: #ccc;
            font-size: 0.8rem;
        }

        @media print {
            body {
                margin: 0;
                padding: 0;
                background: white;
            }
            
            .certificate-page {
                height: auto;
                page-break-inside: avoid;
            }
        }
    </style>
</head>
<body>
    <div class="certificate-page">
        <div class="certificate-container">
            <div class="certificate-content">
                <!-- Header -->
                <div class="certificate-header">
                    <div class="icon-badge">
                        <i class="fas fa-medal"></i>
                    </div>
                    <h1 class="certificate-title">CERTIFICATE OF COMPLETION</h1>
                </div>

                <!-- Main Content -->
                <p class="subtitle">This Certifies That</p>

                <div class="student-name">
                    {{ app.user.fullName }}
                </div>

                <p class="achievement-text">
                    has successfully completed the professional training program
                </p>

                <div class="formation-title">
                    {{ certificate.formation.title }}
                </div>

                <!-- Details Grid -->
                <div class="details-grid">
                    <div class="detail-item">
                        <div class="detail-label">Level</div>
                        <div class="detail-value">{{ certificate.formation.level ?? 'Standard' }}</div>
                    </div>
                    <div class="detail-item">
                        <div class="detail-label">Duration</div>
                        <div class="detail-value">
                            {% if certificate.formation.duration %}
                                {{ certificate.formation.duration }}
                                {% if certificate.formation.duration == 1 %}week{% else %}weeks{% endif %}
                            {% else %}
                                Self-Paced
                            {% endif %}
                        </div>
                    </div>
                    <div class="detail-item">
                        <div class="detail-label">Score</div>
                        <div class="detail-value">{{ certificate.score|round(2) }}%</div>
                    </div>
                </div>

                <!-- Signatures -->
                <div class="signatures-section">
                    <div class="signature-block">
                        <div class="signature-line"></div>
                        <div class="signature-label">
                            <strong>Authorized Signature</strong>
                        </div>
                    </div>
                    <div class="signature-block">
                        <div class="signature-line"></div>
                        <div class="signature-label">
                            <strong>{{ certificate.awardedAt|date('F d, Y') }}</strong><br>
                            <small>Date Awarded</small>
                        </div>
                    </div>
                </div>

                <p class="footer-text">
                    This certificate is earned through successful completion of coursework and assessments.
                </p>

                <div class="certificate-id">
                    Certificate ID: {{ certificate.id }}
                </div>
            </div>
        </div>
    </div>
</body>
</html>
